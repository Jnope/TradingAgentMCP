# ===== LLM 配置 =====
MCP_LLM_PROVIDER=openai
MCP_DEEP_THINK_LLM=gpt-4o
MCP_QUICK_THINK_LLM=gpt-4o-mini
MCP_BACKEND_URL=https://api.openai.com/v1

# LLM Provider API Keys（设置你使用的 Provider 对应的 Key）
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_CN_API_KEY=
ZHIPU_API_KEY=
ZHIPU_CN_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
OPENROUTER_API_KEY=
SILICONFLOW_API_KEY=

# 可选：指定远程 Ollama 服务器
#OLLAMA_BASE_URL=http://your-ollama-host:11434/v1

# 可选：为 deep/quick 模型分别指定 Provider 和 API Key
#MCP_DEEP_PROVIDER=deepseek
#MCP_DEEP_API_KEY=xxx
#MCP_QUICK_PROVIDER=openai
#MCP_QUICK_API_KEY=xxx

# 可选：模型参数微调
#MCP_DEEP_MAX_TOKENS=4096
#MCP_QUICK_MAX_TOKENS=2048
#MCP_DEEP_TEMPERATURE=0.7
#MCP_QUICK_TEMPERATURE=0.3
#MCP_DEEP_TIMEOUT=120
#MCP_QUICK_TIMEOUT=60

# ===== timelyre 内部数据库 =====
JDBC_HTTP_PROXY=172.18.192.74:9998
TM_REAL_CONN=jdbc:hive2://172.18.192.75:10006
TM_DB_NAME=meta_data
TM_DB_USER=admin
TM_DB_PASSWORD=admin
GUARDIAN_TOKEN=
# 查询锁等待超时（秒），默认30
#TM_QUERY_TIMEOUT=30
# DatabaseConn 会话超时（毫秒），默认60000（1分钟），原默认300000（5分钟）
#TM_SESSION_TIMEOUT=60000
# DatabaseConn 登录超时（毫秒），默认15000（15秒），原默认300000（5分钟）
#TM_LOGIN_TIMEOUT=15000

# ===== 运行配置 =====
MCP_PARALLEL_ANALYSTS=true
MCP_MAX_DEBATE_ROUNDS=1
MCP_MAX_RISK_DISCUSS_ROUNDS=1
MCP_CHECKPOINT_ENABLED=false
MCP_BENCHMARK_TICKER=000300
MCP_OUTPUT_LANGUAGE=Chinese
TRADINGAGENTS_LOG_LEVEL=INFO
